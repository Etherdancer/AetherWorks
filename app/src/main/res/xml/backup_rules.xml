<?xml version="1.0" encoding="utf-8"?>
<!--
    IMPORTANT: This file applies ONLY to Android 11 (API 30) and below.
    Android 12+ (API 31+) uses data_extraction_rules.xml instead.
    Both files exclude all app data from cloud backup and device transfer.
    android:allowBackup="false" in the Manifest is the primary control.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="database" path="."/>
    <exclude domain="root" path="."/>
    <exclude domain="file" path="."/>
    <exclude domain="external" path="."/>
</full-backup-content>