rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Blacklist: read-only for all clients, write only via Admin SDK (Cloud Function)
    match /blacklisted_hashes/{hash} {
      allow read: if true;
      allow write: if false; // Only Cloud Functions with Admin SDK may write
    }

    // Trusted drops: authenticated clients may write to their own drop,
    // may only read drops addressed to them (identified by document ID = contentHash)
    match /trusted_drops/{dropId} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null && request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.senderUid == request.auth.uid;
    }

    // Group drops: same as trusted drops
    match /group_drops/{dropId} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null && request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.senderUid == request.auth.uid;
    }

    // Client-submitted reports: write only, no read
    match /reports/{reportId} {
      allow read: if false;
      allow write: if request.auth != null 
                   && request.resource.data.keys().hasOnly(['contentHash', 'reason', 'timestamp']);
    }

    // Global report blacklist submissions: write to subcollection, read for clients for local consensus
    match /global_blacklist/{hash}/reports/{token} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.data.keys().hasOnly(['reportToken', 'timestamp'])
                   && token == request.resource.data.reportToken;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
